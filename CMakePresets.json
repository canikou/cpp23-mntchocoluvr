{
  "version": 6,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "local-msys2-base",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "C:/msys64/ucrt64"
      },
      "environment": {
        "PATH": "C:/msys64/ucrt64/bin;$penv{PATH}"
      }
    },
    {
      "name": "ci-base",
      "hidden": true,
      "inherits": "base"
    },
    {
      "name": "vcpkg-base",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_FEATURE_FLAGS": "manifests"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug (Ninja, local MSYS2 UCRT64)",
      "inherits": "local-msys2-base",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release (Ninja, local MSYS2 UCRT64)",
      "inherits": "local-msys2-base",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "vcpkg-debug",
      "displayName": "Debug (Ninja, local + vcpkg manifest)",
      "inherits": [
        "local-msys2-base",
        "vcpkg-base"
      ],
      "binaryDir": "${sourceDir}/build/vcpkg-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "vcpkg-release",
      "displayName": "Release (Ninja, local + vcpkg manifest)",
      "inherits": [
        "local-msys2-base",
        "vcpkg-base"
      ],
      "binaryDir": "${sourceDir}/build/vcpkg-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "ci-debug",
      "displayName": "CI Debug (Ninja, MSYS2 UCRT64)",
      "inherits": "ci-base",
      "binaryDir": "${sourceDir}/build/ci-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_QT": "OFF",
        "ENABLE_FETCH_TEST_DEPS": "ON"
      }
    },
    {
      "name": "ci-release",
      "displayName": "CI Release (Ninja, MSYS2 UCRT64)",
      "inherits": "ci-base",
      "binaryDir": "${sourceDir}/build/ci-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_QT": "OFF",
        "ENABLE_FETCH_TEST_DEPS": "ON"
      }
    },
    {
      "name": "ci-lint",
      "displayName": "CI Lint (Ninja)",
      "inherits": "ci-base",
      "binaryDir": "${sourceDir}/build/ci-lint",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_QT": "OFF",
        "ENABLE_FETCH_TEST_DEPS": "OFF",
        "ENABLE_CLANG_TOOLS": "ON",
        "BUILD_TESTING": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "vcpkg-debug",
      "configurePreset": "vcpkg-debug"
    },
    {
      "name": "vcpkg-release",
      "configurePreset": "vcpkg-release"
    },
    {
      "name": "ci-debug",
      "configurePreset": "ci-debug"
    },
    {
      "name": "ci-release",
      "configurePreset": "ci-release"
    },
    {
      "name": "ci-lint",
      "configurePreset": "ci-lint"
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release",
      "configurePreset": "release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "vcpkg-debug",
      "configurePreset": "vcpkg-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "vcpkg-release",
      "configurePreset": "vcpkg-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "ci-debug",
      "configurePreset": "ci-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "ci-release",
      "configurePreset": "ci-release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
